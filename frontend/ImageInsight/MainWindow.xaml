<Window x:Class="ImageInsight.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ImageInsight"
        mc:Ignorable="d"
        Title="ImageInsight"
        Height="768"
        Width="1280"
        MinHeight="765"
        MinWidth="1280"
        WindowStyle="None"
        AllowsTransparency="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Navigation Bar -->
        <Grid Background="#222" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="ImageInsight"
                       Foreground="White"
                       Margin="10,10,50,10"/>

            <!-- Navigation buttons -->
            <StackPanel Orientation="Horizontal"
                        Grid.Column="1"
                        HorizontalAlignment="Left">

                <Button x:Name="HomeButton"
                        Content="Home"
                        Click="Home_Click"
                        Background="#00DDDDDD"
                        Foreground="White"
                        BorderBrush="#00707070"
                        Padding="10,1,10,1"
                        Margin="0,0,1,0"/>

                <Button x:Name="ImagesButton"
                        Content="Images"
                        Click="Images_Click"
                        Background="#00DDDDDD"
                        Foreground="White"
                        BorderBrush="#00707070"
                        Padding="10,1,10,1"
                        Margin="0,0,1,0"/>

                <Button x:Name="UsersButton"
                        Content="Users"
                        Click="Users_Click"
                        Background="#00DDDDDD"
                        Foreground="White"
                        BorderBrush="#00707070"
                        Padding="10,1,10,1"
                        Margin="0,0,1,0"/>

                <Button x:Name="SettingsButton"
                        Content="Settings"
                        Click="Settings_Click"
                        Background="#00DDDDDD"
                        Foreground="White"
                        BorderBrush="#00707070"
                        Padding="10,1,10,1"
                        Margin="0,0,1,0"/>
            </StackPanel>

            <!-- Page-specific action buttons -->
            <StackPanel Orientation="Horizontal"
                        Grid.Column="2">

                <Button x:Name="AnalyzeButton"
                        Content="Analyze"
                        Background="#00DDDDDD"
                        Foreground="White"
                        BorderBrush="#00707070"
                        Padding="10,1,10,1"
                        Margin="0,0,1,0"
                        Visibility="Collapsed"/>

                <Button x:Name="UploadButton"
                        Content="Upload new"
                        Background="#00DDDDDD"
                        Foreground="White"
                        BorderBrush="#00707070"
                        Padding="10,1,10,1"
                        Margin="0,0,1,0"
                        Visibility="Collapsed"/>

                <Button x:Name="DeleteImageButton"
                        Content="Delete"
                        Background="#00DDDDDD"
                        Foreground="White"
                        BorderBrush="#00707070"
                        Padding="10,1,10,1"
                        Margin="0,0,1,0"
                        Visibility="Collapsed"/>
            </StackPanel>

            <!-- Window buttons -->
            <StackPanel Orientation="Horizontal"
                        Grid.Column="3">

                <Button Content="—"
                        Width="40"
                        Background="#00000000"
                        Foreground="White"
                        BorderBrush="#00707070"
                        Click="MinimizeWindow"/>

                <Button Content="▢"
                        Width="40"
                        Foreground="White"
                        Background="#00DDDDDD"
                        BorderBrush="#00707070"
                        Click=" ToggleMaximizeRestore"/>

                <Button Content="⨉"
                        Width="40"
                        Background="#00DDDDDD"
                        Foreground="White"
                        BorderBrush="#00707070"
                        Click="CloseApp"/>
            </StackPanel>
        </Grid>

        <!-- Main content -->
        <Frame x:Name="MainFrame"
               Grid.Row="1"
               NavigationUIVisibility="Hidden"/>

        <!-- Loading screen -->
        <Grid x:Name="LoadingOverlay"
              Grid.Row="1"
              Visibility="Collapsed"
              Background="#CD000000"
              Panel.ZIndex="999">

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <TextBlock Text="Analyzing..."
                           Foreground="White"
                           FontSize="25"/>

                <ProgressBar IsIndeterminate="True"
                             Width="200"
                             Height="15"
                             Foreground="DodgerBlue"/>
            </StackPanel>
        </Grid>

        <!-- Result Popup -->
        <Grid x:Name="ResultPopup"
              Grid.Row="1"
              Background="#CD000000"
              Visibility="Collapsed"
              Panel.ZIndex="1000">

            <Border Background="#222"
                    Padding="20"
                    CornerRadius="10"
                    Width="1100"
                    Height="700"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <Image x:Name="AnalyzedImage"
                               Stretch="Uniform"
                               Height="550"/>

                        <TextBlock x:Name="ResultDescription"
                                   Text="Description"
                                   Foreground="White"
                                   FontSize="16"
                                   TextWrapping="Wrap"
                                   Padding="0,15,0,15"/>

                        <TextBlock x:Name="ResultTags"
                                   Text="Tags: ..."
                                   Foreground="#00AEEF"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   Padding="0,15,0,15"/>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,20,0,0">

                            <Button Content="Validate"
                                    Width="100"
                                    FontSize="15"/>

                            <Button Content="Revalidate"
                                    Width="100"
                                    FontSize="15"
                                    Margin="20,0"/>

                            <Button Content="Reject"
                                    Width="100"
                                    FontSize="15"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>