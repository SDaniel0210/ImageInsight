<Page x:Class="ImageInsight.UsersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">
        <DataGrid x:Name="UsersDataGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  LoadingRow="UsersDataGrid_LoadingRow">

            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Add user"
                              Click="AddUser_Click"/>
                </ContextMenu>
            </DataGrid.ContextMenu>

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="*"/>
                <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="120"/>
                <DataGridTextColumn Header="Created At" Binding="{Binding CreatedAt}" Width="160"/>
                <DataGridTextColumn Header="Last Login" Binding="{Binding LastLogin}" Width="160"/>
                <DataGridTextColumn Header="Validated Images" Binding="{Binding ValidatedImagesCount}" Width="140"/>
                <DataGridTextColumn Header="Feedback Count" Binding="{Binding FeedbackCount}" Width="130"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>